<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 채팅/쪽지 서브 페이지 오버레이 WebView (메인 SPA 위에 표시) -->
    <WebView
        android:id="@+id/subWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- NHM-70: foreground 인앱 알림 배너 (WebView 위 오버레이) -->
    <net.spacenx.messenger.ui.InAppBannerView
        android:id="@+id/inAppBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- 개발자용 파일로그 설정 버튼 (우측 세로중앙). 추후 설정탭으로 이관 예정 -->
    <ImageButton
        android:id="@+id/btnDevLog"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="4dp"
        android:src="@android:drawable/ic_menu_manage"
        android:background="@android:color/transparent"
        android:alpha="0.4"
        android:contentDescription="파일 로그 설정"
        android:visibility="visible" />

</FrameLayout>
